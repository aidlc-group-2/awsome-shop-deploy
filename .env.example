# AWSomeShop 环境配置模板 — Unit 7
# 用法：cp .env.example .env，然后填入真实值。真实 .env 不要提交到 git（见 .gitignore）。

# ---------- MySQL ----------
# root 密码（仅容器内使用，请用强随机值）
MYSQL_ROOT_PASSWORD=change-me-root-pass
# 共享应用账号（init SQL 假定用户名为 awsomeshop，请保持一致）
MYSQL_APP_USER=awsomeshop
MYSQL_APP_PASSWORD=change-me-app-pass

# ---------- 安全 ----------
# JWT 签名密钥（auth 与 gateway 共享），至少 32 字节随机串
# 生成示例：openssl rand -base64 48
JWT_SECRET=change-me-please-use-a-long-random-secret

# ---------- 业务配置 ----------
# 注册允许的企业邮箱白名单域名（多个用逗号分隔）
EMAIL_DOMAIN_WHITELIST=example.com
# 新员工入职奖励积分额度
ONBOARDING_POINTS=1000

# ---------- 通用 ----------
TZ=Asia/Shanghai
